generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model commande {
  numero_commande      String   @id @db.VarChar(50)
  date_commande        DateTime @db.Date
  date_prestation      DateTime @db.Date
  heure_livraison      String   @db.VarChar(50)
  prix_menu            Float
  nombre_personne      Int
  prix_livraison       Float
  statut               String   @db.VarChar(50)
  pret_materiel        Boolean
  restitution_materiel Boolean
  client_prenom        String   @db.VarChar(50)
  client_nom           String   @db.VarChar(50)
  client_email         String   @db.VarChar(50)
  client_telephone     String   @db.VarChar(50)
  adresse              String   @db.VarChar(50)
  ville                String   @db.VarChar(50)

  menu_id        Int
  menu           menu          @relation(fields: [menu_id], references: [menu_id])
  utilisateur_id Int
  utilisateur    utilisateur   @relation(fields: [utilisateur_id], references: [utilisateur_id])
  suivis         suivi_statut[]
}

enum statut_suivi {
  Accepte                          @map("Accepté")
  EnPreparation                    @map("En préparation")
  EnCoursDeLivraison               @map("En cours de livraison")
  Livre                            @map("Livré")
  EnAttenteDuRetourDeMateriel      @map("En attente du retour de matériel")
  Terminee                         @map("Terminée")
}

model suivi_statut {
  suivi_id        Int          @id @default(autoincrement())
  statut          statut_suivi
  date_heure      DateTime     @default(now())
  numero_commande String       @db.VarChar(50)
  commande        commande     @relation(fields: [numero_commande], references: [numero_commande])
}

model menu {
  menu_id                 Int    @id @default(autoincrement())
  titre                   String @db.VarChar(50)
  nombre_personne_minimum Int
  prix_par_personne       Float
  regime                  String @db.VarChar(50)
  description             String @db.VarChar(50)
  quantite_restante       Int

  regime_id Int
  regimeRel regime @relation(fields: [regime_id], references: [regime_id])

  theme_id Int
  themeRel theme @relation(fields: [theme_id], references: [theme_id])

  commande commande[]
  plat     plat[]
}

model regime {
  regime_id Int    @id @default(autoincrement())
  libelle   String @db.VarChar(50)
  menu      menu[]
}

model theme {
  theme_id Int    @id @default(autoincrement())
  libelle  String @db.VarChar(50)
  menu     menu[]
}

model utilisateur {
  utilisateur_id  Int    @id @default(autoincrement())
  email           String @db.VarChar(50)
  password        String @db.VarChar(255)
  prenom          String @db.VarChar(50)
  nom             String @db.VarChar(50)
  telephone       String @db.VarChar(50)
  ville           String @db.VarChar(50)
  pays            String @db.VarChar(50)
  adresse_postale String @db.VarChar(50)

  role_id Int
  role    role @relation(fields: [role_id], references: [role_id])

  commande commande[]
  avis     avis[]
}

model role {
  role_id     Int           @id
  libelle     String        @db.VarChar(50)
  utilisateur utilisateur[]
}

model avis {
  avis_id     Int    @id
  note        String @db.VarChar(50)
  description String @db.VarChar(50)
  statut      String @db.VarChar(50)

  utilisateur_id Int
  utilisateur    utilisateur @relation(fields: [utilisateur_id], references: [utilisateur_id])
}

model plat {
  plat_id    Int    @id @default(autoincrement())
  titre_plat String @db.VarChar(50)
  photo      Bytes

  menu      menu[]
  allergene allergene[]
}

model allergene {
  allergene_id Int    @id @default(autoincrement())
  libelle      String @db.VarChar(50)
  plat         plat[]
}

model horaire {
  horaire_id      Int    @id @default(autoincrement())
  jour            String @db.VarChar(50)
  heure_ouverture String @db.VarChar(50)
  heure_fermeture String @db.VarChar(50)
}
